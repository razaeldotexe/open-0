{
  "name": "openzero",
  "version": "1.0.0",
  "description": "Modular Discord bot for searching Open Data",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "deploy": "node src/deploy-commands.js",
    "build": "npm run deploy",
    "test": "node --test",
    "lint": "eslint src/",
    "format": "prettier --write src/ && npm run format:python",
    "format:python": "ruff format flask_api/*.py flask_api/fetchers/*.py || black flask_api/*.py flask_api/fetchers/*.py || echo 'Please install ruff or black to format Python files'",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-username/openzero.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/your-username/openzero/issues"
  },
  "homepage": "https://github.com/your-username/openzero#readme",
  "dependencies": {
    "discord.js": "^14.26.2",
    "dotenv": "^17.4.2",
    "mongodb": "^7.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.2"
  },
  "lint-staged": {
    "src/**/*.{js,json}": [
      "prettier --write",
      "eslint --fix"
    ],
    "flask_api/**/*.py": [
      "ruff format",
      "ruff check --fix"
    ]
  }
}
