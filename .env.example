# Discord Application/Client ID (Required for slash commands)
CLIENT_ID=
# Discord Guild/Server ID (Optional: for instant updates in a specific server)
GUILD_ID=

# Discord Bot Token
DISCORD_TOKEN=

# GitHub Configuration
GITHUB_TOKEN=
GITHUB_REPO_URL=https://github.com/your-username/openzero-resource
GITHUB_REPO_OWNER=your-username
GITHUB_REPO_NAME=openzero-resource

# AI Provider API Keys
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Flask API URL (Default: https://your-api-url.com)
API_URL=https://your-api-url.com

# Translation Project URL (Optional: defaults to Crowdin)
TRANSLATION_URL=

# Discord Admin ID (Required for administrative commands)
ADMIN_ID=

# Application Mode: production | dev
APP_MODE=production

# MongoDB Connection URI
MONGODB_URI=mongodb://localhost:27017/openzero

# Railway API Configuration (Optional: for !restart command)
RAILWAY_API_KEY=
RAILWAY_ENVIRONMENT_ID=
RAILWAY_BOT_SERVICE_ID=
RAILWAY_API_SERVICE_ID=
